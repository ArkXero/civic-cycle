# Supabase
#
#
# hello ghello
#
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (get from console.anthropic.com)
ANTHROPIC_API_KEY=s

# Resend (get from resend.com/api-keys)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Apps
NEXT_PUBLIC_APP_URL=
CRON_SECRET=

# YouTube Data API v3 (for playlist/video metadata)
YOUTUBE_API_KEY=

# YouTube OAuth2 (required for official Captions API download)
# Get from Google Cloud Console > Credentials > OAuth 2.0 Client IDs
# Note: captions.download only works if you own the video or the track has isCC=true.
# If unavailable, transcript extraction automatically falls back to innertube.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
