# Supabase project URL, e.g. https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Browser-safe anonymous key used by the web client
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
# Server-only service role key. Never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (get from console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Resend (get from resend.com/api-keys)
RESEND_API_KEY=your-resend-api-key
# Verified sender address used for outbound alerts
RESEND_FROM_EMAIL=alerts@example.com

# Apps
# Public base URL for links in emails and redirects
NEXT_PUBLIC_APP_URL=https://app.example.com
# Long random bearer token for cron endpoints
CRON_SECRET=replace-with-a-long-random-secret

# Admin access (comma-separated emails)
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# BoardDocs routing values used by server-side imports and health checks
BOARDDOCS_STATE=vsba
BOARDDOCS_DISTRICT=fairfax
